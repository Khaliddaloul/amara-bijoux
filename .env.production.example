# Copy to a secure notes file — never commit real secrets.
# Vercel: Project → Settings → Environment Variables (Production).

# Neon Postgres connection string (starts with postgresql:// or postgres://)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Auth.js / NextAuth signing secret — generate your own:
#   openssl rand -base64 32
# Example below is for illustration only; do not reuse in production.
NEXTAUTH_SECRET="9CXNoHo+jS/6FzJd0FcQ3Ctl2KZ/jOGOHJrRRLXztmE="
# Alias also supported by this project:
# AUTH_SECRET="(same value as NEXTAUTH_SECRET)"

NEXTAUTH_URL="https://amarat.vercel.app"
NEXT_PUBLIC_SITE_URL="https://amarat.vercel.app"

ADMIN_EMAIL="admin@amara.ma"
ADMIN_PASSWORD="Admin@123"

# Admin uploads on Vercel: enable Vercel Blob (Storage → Create → link env), then:
# BLOB_READ_WRITE_TOKEN is injected by the Vercel Blob integration.
# Optional explicit toggle (token alone is enough to use Blob in /api/upload):
# USE_VERCEL_BLOB="true"

# Optional email (transactional / campaigns):
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASSWORD=

# One-time: run seed from your machine after first deploy (see DEPLOY.md).
# Do not leave enabled for routine deploys — seed wipes existing data.
# RUN_DB_SEED="true"
