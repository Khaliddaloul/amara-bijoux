DATABASE_URL="file:./dev.db"
AUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Canonical URL للـ SEO، الـ sitemap، JSON-LD، og:url (بدون شرطة مائية أخيرة).
# التطوير المحلي:
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
# الإنتاج (مثال — عدّلي النطاق لبيئتك):
# NEXT_PUBLIC_SITE_URL="https://amara-bijoux.ma"

# Optional: reduces macOS EMFILE errors from file watchers (polling mode).
# WATCHPACK_POLLING=true
