# Local + CI: use the same Postgres as production (Neon free tier) for fewer surprises.
# Create a branch or database in Neon and paste its connection string:
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# Auth — generate with: openssl rand -base64 32
AUTH_SECRET="generate-with-openssl-rand-base64-32"
# Or use NextAuth name (either works):
# NEXTAUTH_SECRET="same-as-auth-secret"

NEXTAUTH_URL="http://localhost:3000"

# Canonical URL for SEO, sitemap, JSON-LD, og:url (no trailing slash)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Default admin (change in production; match prisma/seed if you re-seed)
ADMIN_EMAIL="admin@amara.ma"
ADMIN_PASSWORD="Admin@123"

# Optional: Vercel Blob for uploads (same token as production if testing uploads locally)
# BLOB_READ_WRITE_TOKEN=

# Optional: reduces macOS EMFILE errors from file watchers (polling mode).
# WATCHPACK_POLLING=true
